<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#f5f5f5">

    <!-- Card Counter -->
    <TextView
        android:id="@+id/tv_card_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="1 / 10"
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginBottom="16dp" />

    <!-- Card Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="8dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp">

            <!-- Russian Word (Original side) -->
            <TextView
                android:id="@+id/tv_russian_word"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Привет"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:gravity="center"
                android:visibility="visible" />

            <!-- English Word (Translation side) -->
            <TextView
                android:id="@+id/tv_english_word"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Hello"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:gravity="center"
                android:visibility="gone" />

            <!-- Transcript (Translation side) -->
            <TextView
                android:id="@+id/tv_transcript"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_english_word"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:text="[həˈloʊ]"
                android:textSize="18sp"
                android:textColor="#666666"
                android:gravity="center"
                android:fontFamily="monospace"
                android:visibility="gone" />

            <!-- Tap to flip hint -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:text="Tap to flip"
                android:textSize="12sp"
                android:textColor="#999999"
                android:alpha="0.7" />

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp">

        <!-- Previous Button -->
        <Button
            android:id="@+id/btn_prev_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Previous"
            android:textSize="16sp"
            android:backgroundTint="#FF9800"
            style="@style/Widget.Material3.Button" />

        <!-- Flip Button -->
        <Button
            android:id="@+id/btn_flip_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:text="Show Translation"
            android:textSize="16sp"
            android:backgroundTint="#2196F3"
            style="@style/Widget.Material3.Button" />

        <!-- Next Button -->
        <Button
            android:id="@+id/btn_next_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Next"
            android:textSize="16sp"
            android:backgroundTint="#4CAF50"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>

    <!-- Additional Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btn_shuffle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Shuffle"
            android:textSize="14sp"
            android:backgroundTint="#9C27B0"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <Button
            android:id="@+id/btn_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Reset"
            android:textSize="14sp"
            android:backgroundTint="#607D8B"
            style="@style/Widget.Material3.Button.OutlinedButton" />

    </LinearLayout>

</LinearLayout>